rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función de ayuda para verificar si un usuario es administrador de forma segura
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    // Productos: Lectura libre, escritura solo admin o stock por sistema
    match /products/{product} {
      allow read: if true;
      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) ||
        isAdmin()
      );
      allow create, delete: if isAdmin();
    }

    // Usuarios: El usuario solo puede acceder a su propio perfil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Listas de Compras: El usuario solo puede acceder a sus propias listas
    match /shoppingLists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Configuración: Lectura pública (sucursales, etc.)
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos: Crear autenticado, leer/actualizar solo dueño o admin
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
    }

    // Ajustes Globales
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Por defecto, denegar todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
